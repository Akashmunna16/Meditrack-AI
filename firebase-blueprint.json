{
  "entities": {
    "patient": {
      "title": "Patient",
      "description": "Patient basic profile and history summary.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "name": { "type": "string", "description": "Full name" },
        "age": { "type": "number", "description": "Current age" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "history": { "type": "string", "description": "Summary of medical history" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "createdAt"]
    },
    "report": {
      "title": "Medical Report",
      "description": "Analyzed medical reports (PDF/Images).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Patient UID or owner UID" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "summary": { "type": "string", "description": "AI-generated summary" },
        "rawText": { "type": "string", "description": "OCR extracted text" },
        "keyInsights": { "type": "array", "items": { "type": "string" } },
        "urgentActions": { "type": "array", "items": { "type": "string" } },
        "biomarkers": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "number" },
              "unit": { "type": "string" },
              "category": { "type": "string" }
            }
          } 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "summary", "createdAt"]
    },
    "biomarkerTrend": {
      "title": "Biomarker Trend",
      "description": "Historical data point for a specific biomarker.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "reportId": { "type": "string" },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "value", "recordedAt"]
    },
    "chatMessage": {
      "title": "Chat Message",
      "description": "Messages for the Med-Chat RAG system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "content", "createdAt"]
    },
    "medication": {
      "title": "Medication",
      "description": "Information about patient medications and schedule.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "dosage": { "type": "string" },
        "frequency": { "type": "string" },
        "remainingTablets": { "type": "number" },
        "totalTablets": { "type": "number" },
        "lowThreshold": { "type": "number" },
        "schedule": { "type": "array", "items": { "type": "string" }, "description": "Times of day in HH:mm format" },
        "lastTaken": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "dosage", "remainingTablets"]
    },
    "medicationLog": {
      "title": "Medication Log",
      "description": "Historical record of medication adherence.",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["taken", "skipped"] },
        "scheduledTime": { "type": "string" },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "date", "timestamp"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "patient",
      "description": "Stores individual patient records."
    },
    "/patients/{patientId}/reports/{reportId}": {
      "schema": "report",
      "description": "Stores medical reports for a specific patient."
    },
    "/patients/{patientId}/trends/{trendId}": {
      "schema": "biomarkerTrend",
      "description": "Stores individual biomarker data points for tracking."
    },
    "/patients/{patientId}/medications/{medicationId}": {
      "schema": "medication",
      "description": "Stores current medications and schedule for a patient."
    },
    "/patients/{patientId}/medications/{medicationId}/logs/{logId}": {
      "schema": "medicationLog",
      "description": "Stores individual therapy adherence events."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "chatMessage",
      "description": "Stores user chat history with Meditrack AI."
    }
  }
}
